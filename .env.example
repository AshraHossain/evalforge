##############################################################################
# EvalForge — Environment Variables
# Copy to .env and fill in your values.
# .env is gitignored — never commit secrets.
##############################################################################

# ── Database ──────────────────────────────────────────────────────────────────
# Async SQLAlchemy URL (postgresql+asyncpg://...)
DATABASE_URL=postgresql+asyncpg://evalforge:evalforge@localhost:5432/evalforge

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Ollama ────────────────────────────────────────────────────────────────────
# Point this at your local Ollama server.
# Default is http://localhost:11434 — change if Ollama is on another host.
# MODEL is the Ollama model tag.  Run `ollama pull gemma4:26b` first.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:26b

# ── JWT Auth ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-before-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── LangSmith (optional) ──────────────────────────────────────────────────────
# Set to 1 to enable full agent tracing at smith.langchain.com
LANGCHAIN_TRACING_V2=0
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=evalforge

# ── HITL threshold ────────────────────────────────────────────────────────────
# If hallucination_rate in a run exceeds this, the graph pauses for human review
HITL_HALLUCINATION_THRESHOLD=0.3

# ── Postgres (for docker-compose) ─────────────────────────────────────────────
POSTGRES_USER=evalforge
POSTGRES_PASSWORD=evalforge
POSTGRES_DB=evalforge
